<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fxt.newgb.mapper.help.HelpDocContentMapper">

    <resultMap id="HelpDocContentVOMap" type="com.fxt.newgb.vo.app.HelpDocContentVO">
        <id column="id" property="id"/>
        <result column="sort" property="sort"/>
        <result column="content" property="content"/>
        <result column="image_url" property="imageUrl"/>
    </resultMap>

    <select id="selectByDocId" resultType="com.fxt.newgb.entity.help.HelpDocContent">
        SELECT
            id,
            sort,
            content,
            image_url
        FROM help_doc_content
        WHERE deleted = 0
          AND doc_id = #{docId}
        ORDER BY sort ASC
    </select>

</mapper>
